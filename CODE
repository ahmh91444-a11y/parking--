import csv 
from parking import Slot 
 
def save_slots(filename, slots): 
    with open(filename, "w", newline="") as f: 
        w = csv.writer(f) 
        w.writerow(["slot_id", "slot_type", "status", "updated"]) 
        for s in slots.values(): 
            w.writerow(s.as_list()) 
 
def load_slots(filename, lot): 
    try: 
        with open(filename, "r") as f: 
            r = csv.reader(f) 
            next(r) 
            for row in r: 
                lot.slots[row[0]] = Slot(row[0], row[1], row[2]) 
                lot.slots[row[0]].updated = row[3] 
    except FileNotFoundError: 
        pass 
 
def save_logs(filename, logs): 
    with open(filename, "w", newline="") as f: 
        w = csv.writer(f) 
        w.writerow(["slot_id", "action", "time"]) 
        w.writerows(logs) 
 
import numpy as np 
import pandas as pd 
 
def show_analytics(slot_file, log_file): 
    df = pd.read_csv(slot_file) 
    total = len(df) 
    free = len(df[df["status"] == "Free"])
 occupied = len(df[df["status"] == "Occupied"]) 
    reserved = len(df[df["status"] == "Reserved"]) 
    values = np.array([free, occupied, reserved]) 
 
    print("\nTotal:", total) 
    print("Free:", free) 
    print("Occupied:", occupied) 
    print("Reserved:", reserved) 
    print("Mean status count:", np.mean(values)) 
    if total: 
        print("Occupancy %:", round((occupied / total) * 100, 2)) 
 
    try: 
        logs = pd.read_csv(log_file) 
        if not logs.empty: 
            print("Most active slot:") 
            print(logs["slot_id"].value_counts().head(1)) 
    except FileNotFoundError: 
        pass 
 
 
 
import pandas as pd 
import matplotlib.pyplot as plt 
 
def make_charts(slot_file): 
    df = pd.read_csv(slot_file) 
    counts = df["status"].value_counts() 
    types = df["slot_type"].value_counts() 
 
    counts.plot(kind="bar", color=["green", "red", "blue"]) 
    plt.title("Parking Status") 
    plt.tight_layout() 
    plt.savefig("status_chart.png") 
    plt.clf() 
 
    types.plot(kind="pie", autopct="%1.0f%%") 
    plt.title("Slot Types") 
    plt.ylabel("") 
    plt.tight_layout() 
    plt.savefig("type_chart.png") 
    plt.clf() 
 
    print("Charts created: status_chart.png, type_chart.png") 
