from datetime import datetime 
 
class Slot: 
    def __init__(self, slot_id, slot_type, status="Free"): 
        self.slot_id = slot_id 
        self.slot_type = slot_type 
        self.status = status 
        self.updated = datetime.now().strftime("%Y-%m-%d %H:%M:%S") 
 
    def as_list(self): 
        return [self.slot_id, self.slot_type, self.status, self.updated] 
 
class ParkingLot: 
    def __init__(self): 
        self.slots = {} 
        self.types = {"Regular", "EV", "Accessible"} 
        self.logs = [] 
 
    def add_slot(self, slot_id, slot_type, status="Free"): 
        if slot_type in self.types and slot_id not in self.slots: 
            self.slots[slot_id] = Slot(slot_id, slot_type, status) 
 
    def show_slots(self): 
        print("\nID\tType\t\tStatus") 
        for s in self.slots.values(): 
            print(s.slot_id, "\t", s.slot_type, "\t", s.status) 
 
    def update_status(self, slot_id, status): 
        if slot_id in self.slots:
  self.slots[slot_id].status = status 
            self.slots[slot_id].updated = datetime.now().strftime("%Y-%m-%d %H:%M:%S") 
            log = (slot_id, status, self.slots[slot_id].updated) 
            self.logs.append(log) 
            return log 
 
    def allocate_slot(self, vehicle_type): 
        order = [vehicle_type, "Regular"] if vehicle_type in ["EV", "Accessible"] else 
["Regular"] 
        for t in order: 
            for s in self.slots.values(): 
                if s.slot_type == t and s.status == "Free": 
                    return self.update_status(s.slot_id, "Occupied") 
        return None 
